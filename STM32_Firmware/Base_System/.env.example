# Base System — Environment Configuration
# ----------------------------------------
# Copy this file to .env and fill in your serial port.
#
# macOS example:
#   SERIAL_PORT=/dev/tty.usbmodem1234
#
# Linux example:
#   SERIAL_PORT=/dev/ttyACM0
#
# Windows (WSL2) example:
#   SERIAL_PORT=/dev/ttyS3
#   (COM3 in Windows = /dev/ttyS3 in WSL2)

SERIAL_PORT=/dev/tty.usbmodem1203
